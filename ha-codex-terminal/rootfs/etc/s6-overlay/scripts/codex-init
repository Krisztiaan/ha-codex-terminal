#!/command/with-contenv bashio
set -euo pipefail

DATA_DIR="/data"
PERSIST_CODEX_DIR="${DATA_DIR}/codex_home"
CODEX_DIR="/root/.codex"

mkdir -p "${DATA_DIR}" "${PERSIST_CODEX_DIR}"

if [ ! -L "${CODEX_DIR}" ]; then
    rm -rf "${CODEX_DIR}"
    ln -s "${PERSIST_CODEX_DIR}" "${CODEX_DIR}"
fi

# Expose a single persistent Codex home for all processes.
printf '%s' "${PERSIST_CODEX_DIR}" > /run/s6/container_environment/CODEX_HOME

write_option_file() {
    local option="$1"
    local target="$2"
    local mode="$3"
    local value

    value="$(bashio::config "${option}")"
    if ! bashio::var.has_value "${value}"; then
        return 1
    fi

    local tmp_file
    tmp_file="$(mktemp)"
    printf '%s' "${value}" > "${tmp_file}"
    mv "${tmp_file}" "${target}"
    chmod "${mode}" "${target}"
    return 0
}

seed_file_if_missing() {
    local source="$1"
    local target="$2"
    local mode="$3"
    local label="$4"

    if [ -f "${target}" ] || [ -L "${target}" ]; then
        return 0
    fi

    if [ -f "${source}" ]; then
        cp "${source}" "${target}"
        chmod "${mode}" "${target}"
        bashio::log.info "Seeded ${label} into ${target}."
    fi
}

# Migrate legacy /data/* artifacts into CODEX_HOME on first start after upgrade.
for legacy in "auth.json" "config.toml" "AGENTS.md"; do
    if [ -f "${DATA_DIR}/${legacy}" ] && [ ! -f "${PERSIST_CODEX_DIR}/${legacy}" ]; then
        cp "${DATA_DIR}/${legacy}" "${PERSIST_CODEX_DIR}/${legacy}"
        chmod 600 "${PERSIST_CODEX_DIR}/${legacy}" 2>/dev/null || true
        bashio::log.info "Imported legacy /data/${legacy} into ${PERSIST_CODEX_DIR}/${legacy}."
    fi
done

# Seed auth once from add-on options (and keep refreshed auth.json as canonical state).
AUTH_SEED_OPTION="auth_json_seed"
if ! bashio::var.has_value "$(bashio::config "${AUTH_SEED_OPTION}")"; then
    # Back-compat for older config.yaml that used auth_json.
    AUTH_SEED_OPTION="auth_json"
fi

if [ ! -f "${PERSIST_CODEX_DIR}/auth.json" ]; then
    if write_option_file "${AUTH_SEED_OPTION}" "${PERSIST_CODEX_DIR}/auth.json" 600; then
        bashio::log.info "Seeded auth.json from ${AUTH_SEED_OPTION} option."
    fi
else
    if bashio::var.has_value "$(bashio::config "${AUTH_SEED_OPTION}")"; then
        bashio::log.info "auth.json already present; ignoring ${AUTH_SEED_OPTION} seed."
    fi
fi

# Allow config/AGENTS to be managed via add-on options; blanks never delete files.
if write_option_file "config_toml" "${PERSIST_CODEX_DIR}/config.toml" 600; then
    bashio::log.info "Updated config.toml from config_toml option."
fi
if write_option_file "agents_md" "${PERSIST_CODEX_DIR}/AGENTS.md" 600; then
    bashio::log.info "Updated AGENTS.md from agents_md option."
fi

DEFAULT_AGENTS_TEMPLATE="/etc/codex/AGENTS.md"
DEFAULT_CONFIG_TEMPLATE="/etc/codex/config.toml"

seed_file_if_missing "${DEFAULT_AGENTS_TEMPLATE}" "${PERSIST_CODEX_DIR}/AGENTS.md" 600 "AGENTS.md"
seed_file_if_missing "${DEFAULT_CONFIG_TEMPLATE}" "${PERSIST_CODEX_DIR}/config.toml" 600 "config.toml"

# Bound persistent Codex artifacts so backups don't grow without limit.
LOG_MAX_MB="$(bashio::config 'codex_log_max_mb' 2>/dev/null || echo '')"
SESSIONS_RETENTION_DAYS="$(bashio::config 'codex_sessions_retention_days' 2>/dev/null || echo '')"

if [ -n "${LOG_MAX_MB}" ] && [ "${LOG_MAX_MB}" -gt 0 ] 2>/dev/null; then
    LOG_FILE="${PERSIST_CODEX_DIR}/log/codex-tui.log"
    if [ -f "${LOG_FILE}" ]; then
        MAX_BYTES="$((LOG_MAX_MB * 1024 * 1024))"
        CUR_BYTES="$(wc -c < "${LOG_FILE}" 2>/dev/null || echo 0)"
        if [ "${CUR_BYTES}" -gt "${MAX_BYTES}" ] 2>/dev/null; then
            tmp_file="$(mktemp)"
            tail -c "${MAX_BYTES}" "${LOG_FILE}" > "${tmp_file}" || true
            mv "${tmp_file}" "${LOG_FILE}"
            chmod 600 "${LOG_FILE}" 2>/dev/null || true
            bashio::log.info "Trimmed codex-tui.log to ~${LOG_MAX_MB}MB."
        fi
    fi
fi

if [ -n "${SESSIONS_RETENTION_DAYS}" ] && [ "${SESSIONS_RETENTION_DAYS}" -gt 0 ] 2>/dev/null; then
    SESS_DIR="${PERSIST_CODEX_DIR}/sessions"
    if [ -d "${SESS_DIR}" ]; then
        find "${SESS_DIR}" -type f -name '*.jsonl' -mtime "+${SESSIONS_RETENTION_DAYS}" -delete 2>/dev/null || true
        find "${SESS_DIR}" -type d -empty -delete 2>/dev/null || true
    fi
fi

# Keep tool caches ephemeral so backups stay lean (Codex CLI itself is installed in the image).
mkdir -p \
    /tmp/.npm \
    /tmp/.npm-global/bin \
    /tmp/.cache/pip \
    /tmp/.cache/yarn \
    /tmp/.cache/corepack \
    /tmp/.cache/pycache \
    /tmp/.local/bin \
    /tmp/.local/pipx \
    /tmp/.local/share/pnpm/store
printf '%s' "/tmp/.npm" > /run/s6/container_environment/NPM_CONFIG_CACHE
printf '%s' "/tmp/.cache" > /run/s6/container_environment/XDG_CACHE_HOME
printf '%s' "/tmp/.cache/pip" > /run/s6/container_environment/PIP_CACHE_DIR
printf '%s' "/tmp/.cache/pycache" > /run/s6/container_environment/PYTHONPYCACHEPREFIX
printf '%s' "/tmp/.local" > /run/s6/container_environment/PYTHONUSERBASE
printf '%s' "/tmp/.local/pipx" > /run/s6/container_environment/PIPX_HOME
printf '%s' "/tmp/.local/bin" > /run/s6/container_environment/PIPX_BIN_DIR
printf '%s' "/tmp/.cache/yarn" > /run/s6/container_environment/YARN_CACHE_FOLDER
printf '%s' "/tmp/.cache/corepack" > /run/s6/container_environment/COREPACK_HOME
printf '%s' "/tmp/.local/share/pnpm" > /run/s6/container_environment/PNPM_HOME
printf '%s' "/tmp/.local/share/pnpm/store" > /run/s6/container_environment/PNPM_STORE_DIR
printf '%s' "/tmp/.npm-global" > /run/s6/container_environment/NPM_CONFIG_PREFIX
printf '%s' "/tmp" > /run/s6/container_environment/TMPDIR
